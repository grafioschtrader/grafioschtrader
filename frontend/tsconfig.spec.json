{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["vitest", "vitest/globals", "vitest/importMeta"],
    "lib": ["ES2022", "ESNext.Disposable", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.spec.ts", "src/**/*.ts"]
}
